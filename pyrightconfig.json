{
  "venvPath": ".",
  "venv": "venv",
  "pythonVersion": "3.14",
  "pythonPlatform": "Darwin",
  "include": [
    "ai_oracle",
    "migrations"
  ],
  "exclude": [
    "venv",
    "build",
    "**/__pycache__"
